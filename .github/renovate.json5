{
  extends: [
    'config:best-practices',
    'schedule:daily',
  ],
  commitMessageSuffix: ' in {{packageFile}}',
  automerge: true,
  automergeType: 'pr',
  automergeStrategy: 'rebase',
  platformAutomerge: false,
  minimumReleaseAge: '2 days',
  internalChecksFilter: 'strict',
  labels: [
    'dependencies',
  ],
  vulnerabilityAlerts: {
    enabled: true,
    labels: [
      'security',
    ],
  },
  packageRules: [
    {
      matchUpdateTypes: [
        'major',
      ],
      automerge: false,
    },
    {
      matchUpdateTypes: [
        'minor',
      ],
      automerge: true,
      groupName: 'minor updates',
    },
    {
      matchUpdateTypes: [
        'patch',
      ],
      automerge: true,
      groupName: 'patch updates',
    },
  ],
}
